{
  "headers": [
    {
      "source": "/icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/apple-touch-icon.png",
      "destination": "/icon.png"
    },
    {
      "source": "/apple-touch-icon-precomposed.png",
      "destination": "/icon.png"
    },
    {
      "source": "/favicon.png",
      "destination": "/icon.png"
    }
  ]
}
